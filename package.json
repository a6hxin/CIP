{
  "name": "codebase-intelligence-platform",
  "version": "1.0.0",
  "description": "A powerful platform for codebase analysis including complexity analysis, dependency scanning, commit timeline, and architecture visualization",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest --coverage",
    "setup": "bash scripts/setup.sh",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "simple-git": "^3.20.0",
    "axios": "^1.6.0",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "lodash": "^4.17.21",
    "semver": "^7.5.4",
    "node-fetch": "^2.7.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "archiver": "^6.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["codebase", "analysis", "complexity", "dependency", "git", "architecture"],
  "author": "",
  "license": "MIT"
}
