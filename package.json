{
  "name": "codebase-intelligence-platform",
  "version": "1.0.0",
  "description": "A powerful platform for codebase analysis including complexity analysis, dependency scanning, commit timeline, and architecture visualization",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest --coverage",
    "setup": "bash scripts/setup.sh",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fs-extra": "^11.3.4",
    "glob": "^10.5.0",
    "helmet": "^7.1.0",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "semver": "^7.5.4",
    "simple-git": "^3.33.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "codebase",
    "analysis",
    "complexity",
    "dependency",
    "git",
    "architecture"
  ],
  "author": "",
  "license": "MIT"
}
   "scripts": {
  "dev": "nodemon --ignore 'data/*' --ignore 'frontend/*' backend/server.js",
  "start": "node backend/server.js"
}