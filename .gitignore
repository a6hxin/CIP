# ───────────────────────────────
# Dependencies
# ───────────────────────────────
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ───────────────────────────────
# Environment & Secrets
# ───────────────────────────────
.env
.env.local
.env.production
.env.development

# ───────────────────────────────
# Cloned Repos (runtime data)
# ───────────────────────────────
data/repos/*/

# ───────────────────────────────
# Generated Reports
# ───────────────────────────────
data/dependency_reports/*.json
data/complexity_reports/*.json

# ───────────────────────────────
# Logs
# ───────────────────────────────
logs/
*.log
npm-debug.log*
nodemon-debug.log*

# ───────────────────────────────
# OS Files
# ───────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────
# IDE / Editor
# ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ───────────────────────────────
# Build Output
# ───────────────────────────────
dist/
build/
.cache/
coverage/

# ───────────────────────────────
# Diagrams (generated at runtime)
# ───────────────────────────────
diagrams/*.png
diagrams/*.svg
!diagrams/.gitkeep

# ───────────────────────────────
# Data folders (keep structure)
# ───────────────────────────────
!data/repos/.gitkeep
!data/dependency_reports/.gitkeep
!data/complexity_reports/.gitkeep

# ───────────────────────────────
# Python
# ───────────────────────────────
*.egg-info/
*.egg
dist/